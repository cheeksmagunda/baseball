# Baseball DFS Engine Configuration
# Copy to .env and customize

# Database (SQLite default, or use postgres:// for Railway Postgres)
# DFS_DATABASE_URL=sqlite:///./db/baseball_dfs.db

# CORS origins (comma-separated, or * for all)
# DFS_CORS_ORIGINS=["http://localhost:3000"]

# MLB season
# DFS_CURRENT_SEASON=2026

# Log level
# DFS_LOG_LEVEL=INFO

# Redis URL (optional but recommended for Railway deploys)
# On Railway: set DFS_REDIS_URL=${{Redis.REDIS_URL}} in your backend service variables
# DFS_REDIS_URL=redis://localhost:6379/0
