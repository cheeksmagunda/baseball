# Ben Oracle Configuration
# Copy to .env and customize

# Database (SQLite default, or use postgres:// for Railway Postgres)
# BO_DATABASE_URL=sqlite:///./db/ben_oracle.db

# CORS origins (comma-separated, or * for all)
# BO_CORS_ORIGINS=["http://localhost:3000"]

# MLB season year (REQUIRED — no default; startup fails if unset).
# One MLB season is contained within a single calendar year. Set this to the
# year of the regular season Ben Oracle is running against. Change once a year
# when spring training ends. See "MLB Season Calendar" in CLAUDE.md.
BO_CURRENT_SEASON=2026

# Log level
# BO_LOG_LEVEL=INFO

# Redis URL (REQUIRED — startup fails if unreachable; no fallback to DB-only cache)
# On Railway: set BO_REDIS_URL=${{Redis.REDIS_URL}} in your backend service variables
# BO_REDIS_URL=redis://localhost:6379/0

# The Odds API key (REQUIRED — T-65 pipeline raises RuntimeError if unset or unreachable).
# Get a free key at https://the-odds-api.com (500 req/month free tier, enough for 1 run/day).
# Vegas lines (moneyline + O/U) are mandatory inputs to pitcher and batter env scoring.
# BO_ODDS_API_KEY=your_key_here
