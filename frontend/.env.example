# Backend API URL — used by Next.js rewrites to proxy /api/* requests (server-side only)
# Development: http://localhost:8000 (FastAPI backend)
# Production (Railway): Set via BACKEND_URL environment variable pointing to backend service
# If neither is set, defaults to http://localhost:8000
API_URL=http://localhost:8000

# Alternative variable name (checked if API_URL is not set)
# BACKEND_URL=http://backend:8000

# Port for the frontend server (Railway sets this automatically)
PORT=3000
