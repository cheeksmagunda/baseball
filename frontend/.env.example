# Backend API URL — used by the Next.js API proxy to forward /api/* requests (server-side only)
# Development: http://localhost:8000
# Production (Railway): http://web.railway.internal:8000  (backend private hostname)
# Falls back to http://localhost:8000 if neither is set
API_URL=http://localhost:8000

# Port for the frontend server (Railway injects this automatically — do not set manually)
# PORT=3000
